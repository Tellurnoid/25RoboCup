{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "type": "shell",
      "command": "arduino-cli compile --fqbn esp32:esp32:esp32 --verbose .",
      "group": "build"
    },
    {
      "label": "upload",
      "type": "shell",
      "command": "arduino-cli upload -p /dev/ttyUSB0 --fqbn esp32:esp32:esp32 --verbose .",
      "dependsOn": "compile"
    }
  ]
}